{
  "name": "opencode-token-menubar",
  "version": "0.1.0",
  "private": true,
  "description": "macOS menubar dashboard for OpenCode token metrics",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.json && esbuild src/main/preload.ts --bundle --platform=node --format=cjs --outfile=dist/main/preload.cjs --external:electron",
    "build": "bun run build:renderer && bun run build:main",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron .",
    "dev:app": "bun run build:main && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron .",
    "dist": "bun run build && electron-builder --mac --universal"
  },
  "author": "fcw",
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "chokidar": "^5.0.0",
    "node-sqlite3-wasm": "^0.8.58",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "ai.opencode.token-menubar",
    "productName": "OpenCode Token Menubar",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "plugin/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["universal"] },
        { "target": "zip", "arch": ["universal"] }
      ]
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  }
}
